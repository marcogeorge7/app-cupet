default_platform(:ios)

# Runs in CI after `flutter build ios --release --no-codesign` has compiled the
# Dart/engine side (version + build number are baked into Generated.xcconfig by
# that step). This lane signs + archives and ships the build to TestFlight; the
# App Store submission is then done manually in App Store Connect. See
# fastlane/SETUP.md for required secrets.
platform :ios do
  desc "Archive and upload to TestFlight (submit for review manually in App Store Connect)"
  lane :beta do
    key_id = ENV.fetch("ASC_KEY_ID")
    issuer_id = ENV.fetch("ASC_ISSUER_ID")

    # Write the base64 .p8 to a file so both xcodebuild (signing) and the upload
    # step can use the App Store Connect API key.
    require "base64"
    require "tmpdir"
    key_path = File.join(Dir.tmpdir, "asc_api_key.p8")
    File.write(key_path, Base64.decode64(ENV.fetch("ASC_KEY_P8")))

    api_key = app_store_connect_api_key(
      key_id: key_id,
      issuer_id: issuer_id,
      key_filepath: key_path,
    )

    # The distribution certificate (+ private key) is imported into the keychain
    # by the workflow's "Import distribution certificate" step before this runs.
    # With the cert present we can fetch/create the matching App Store profile and
    # sign manually — deterministic and stable across CI runs.
    get_provisioning_profile(
      api_key: api_key,
      app_identifier: "app.cupet.cupetApp",
    )
    profile_name = lane_context[SharedValues::SIGH_NAME]

    build_app(
      workspace: "Runner.xcworkspace",
      scheme: "Runner",
      configuration: "Release",
      output_directory: "build",
      output_name: "cupet.ipa",
      export_method: "app-store",
      xcargs: "CODE_SIGN_STYLE=Manual " \
              "DEVELOPMENT_TEAM=MR6847N3F7 " \
              "PROVISIONING_PROFILE_SPECIFIER='#{profile_name}' " \
              "CODE_SIGN_IDENTITY='Apple Distribution'",
      export_options: {
        method: "app-store",
        signingStyle: "manual",
        teamID: "MR6847N3F7",
        provisioningProfiles: { "app.cupet.cupetApp" => profile_name },
        # No Crashlytics, so skip dSYM upload — silences the "Upload Symbols
        # Failed" warnings for Runner.app / objective_c.
        uploadSymbols: false,
      },
    )

    # Upload the build to TestFlight. The App Store submission is done manually
    # in App Store Connect, so there's no need to wait for processing here.
    upload_to_testflight(
      api_key: api_key,
      ipa: "build/cupet.ipa",
      distribute_external: false,
      skip_waiting_for_build_processing: true,
    )
  end
end
