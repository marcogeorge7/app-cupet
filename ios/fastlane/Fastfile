default_platform(:ios)

# Runs in CI after `flutter build ios --release --no-codesign` has compiled the
# Dart/engine side (version + build number are baked into Generated.xcconfig by
# that step). This lane signs + archives and ships the build to TestFlight; the
# App Store submission is then done manually in App Store Connect. See
# fastlane/SETUP.md for required secrets.
platform :ios do
  desc "Archive and upload to TestFlight (submit for review manually in App Store Connect)"
  lane :beta do
    key_id = ENV.fetch("ASC_KEY_ID")
    issuer_id = ENV.fetch("ASC_ISSUER_ID")

    # Write the base64 .p8 to a file so both xcodebuild (signing) and the upload
    # step can use the App Store Connect API key.
    require "base64"
    require "tmpdir"
    key_path = File.join(Dir.tmpdir, "asc_api_key.p8")
    File.write(key_path, Base64.decode64(ENV.fetch("ASC_KEY_P8")))

    api_key = app_store_connect_api_key(
      key_id: key_id,
      issuer_id: issuer_id,
      key_filepath: key_path,
    )

    # Fetch/create the App Store profile (installed locally) so the EXPORT step
    # can reference it by name. The distribution cert was imported by the
    # workflow step before this runs.
    get_provisioning_profile(
      api_key: api_key,
      app_identifier: "app.cupet.cupetApp",
    )
    profile_name = lane_context[SharedValues::SIGH_NAME]

    build_app(
      workspace: "Runner.xcworkspace",
      scheme: "Runner",
      configuration: "Release",
      output_directory: "build",
      output_name: "cupet.ipa",
      export_method: "app-store",
      # ARCHIVE with AUTOMATIC signing. A global manual profile (xcargs) gets
      # applied to every target, but the Swift Package / Pod dependencies
      # (Firebase, GoogleUtilities, AblyDeltaCodec, …) can't take a provisioning
      # profile and error out. The API key + imported dist cert let Xcode resolve
      # the Runner app's signing; dependencies sign with no profile, as required.
      xcargs: "-allowProvisioningUpdates " \
              "-authenticationKeyPath #{key_path} " \
              "-authenticationKeyID #{key_id} " \
              "-authenticationKeyIssuerID #{issuer_id}",
      # The EXPORT only signs the app, so an explicit profile mapping here is safe
      # (this is what the automatic export couldn't resolve on Xcode 26).
      export_options: {
        method: "app-store",
        signingStyle: "manual",
        teamID: "MR6847N3F7",
        provisioningProfiles: { "app.cupet.cupetApp" => profile_name },
        # No Crashlytics, so skip dSYM upload — silences the "Upload Symbols
        # Failed" warnings for Runner.app / objective_c.
        uploadSymbols: false,
      },
    )

    # Upload the build to TestFlight. The App Store submission is done manually
    # in App Store Connect, so there's no need to wait for processing here.
    upload_to_testflight(
      api_key: api_key,
      ipa: "build/cupet.ipa",
      distribute_external: false,
      skip_waiting_for_build_processing: true,
    )
  end
end
