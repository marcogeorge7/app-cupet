default_platform(:ios)

# Runs in CI after `flutter build ios --release --no-codesign` has compiled the
# Dart/engine side (version + build number are baked into Generated.xcconfig by
# that step). This lane signs + archives and ships the build to TestFlight; the
# App Store submission is then done manually in App Store Connect. See
# fastlane/SETUP.md for required secrets.
platform :ios do
  desc "Archive and upload to TestFlight (submit for review manually in App Store Connect)"
  lane :beta do
    api_key = app_store_connect_api_key(
      key_id: ENV.fetch("ASC_KEY_ID"),
      issuer_id: ENV.fetch("ASC_ISSUER_ID"),
      key_content: ENV.fetch("ASC_KEY_P8"),
      is_key_content_base64: true,
    )

    build_app(
      workspace: "Runner.xcworkspace",
      scheme: "Runner",
      configuration: "Release",
      output_directory: "build",
      output_name: "cupet.ipa",
      export_method: "app-store",
      # Automatic signing: xcodebuild creates/fetches the distribution cert + App
      # Store profile for team MR6847N3F7 using the App Store Connect API key, so
      # there is no cert/profile to manage in CI.
      api_key: api_key,
      xcargs: "-allowProvisioningUpdates",
      export_options: {
        method: "app-store",
        teamID: "MR6847N3F7",
        signingStyle: "automatic",
        # No Crashlytics, so skip dSYM upload — silences the "Upload Symbols
        # Failed" warnings for Runner.app / objective_c.
        uploadSymbols: false,
      },
    )

    # Upload the build to TestFlight. The App Store submission is done manually
    # in App Store Connect, so there's no need to wait for processing here.
    upload_to_testflight(
      api_key: api_key,
      ipa: "build/cupet.ipa",
      distribute_external: false,
      skip_waiting_for_build_processing: true,
    )
  end
end
